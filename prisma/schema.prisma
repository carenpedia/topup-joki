generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String               @id @default(cuid())
  username         String               @unique
  passwordHash     String
  whatsapp         String
  role             UserRole             @default(MEMBER)
  status           UserStatus           @default(ACTIVE)
  carencoinBalance Int                  @default(0)
  pointsBalance    Int                  @default(0)
  resellerJoinedAt DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  auditLogs        AdminAuditLog[]      @relation("AdminActor")
  carencoinLedger  CarenCoinLedger[]
  deposits         Deposit[]
  orders           Order[]
  resetTokens      PasswordResetToken[]
  pointLedger      PointLedger[]
  supportTickets   SupportTicket[]
  ticketReplies    TicketReply[]
  voucherUses      VoucherUse[]

  @@index([role])
  @@index([status])
}

model Game {
  id                String            @id @default(cuid())
  key               String            @unique
  name              String
  logoUrl           String?
  isActive          Boolean           @default(true)
  isPopuler         Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  hasJoki           Boolean           @default(false)
  bannerUrl         String?
  targetType        String            @default("DEFAULT")
  links             GameCategory[]
  orders            Order[]
  products          Product[]
  productCategories ProductCategory[]
  reviews           ProductReview[]

  @@index([isActive])
  @@index([isPopuler])
}

model Category {
  id        String         @id @default(cuid())
  name      String         @unique
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  links     GameCategory[]

  @@index([isActive])
}

model GameCategory {
  id         String   @id @default(cuid())
  gameId     String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, categoryId])
  @@index([categoryId])
}

model Product {
  id                String           @id @default(cuid())
  gameId            String
  name              String
  group             ProductGroup
  provider          Provider
  providerSku       String
  isActive          Boolean          @default(true)
  minPayable        Int?
  productCategoryId String?
  createdAt         DateTime         @default(now())
  type              ProductType      @default(TOPUP)
  imageUrl          String?
  updatedAt         DateTime         @updatedAt
  flashSales        FlashSale[]
  orders            Order[]
  game              Game             @relation(fields: [gameId], references: [id], onDelete: Cascade)
  productCategory   ProductCategory? @relation(fields: [productCategoryId], references: [id])
  prices            ProductPrice[]

  @@index([gameId, isActive])
  @@index([provider])
  @@index([group])
}

model ProductPrice {
  id        String   @id @default(cuid())
  productId String
  audience  Audience
  price     Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, audience])
  @@index([audience])
}

model PromoBanner {
  id        String   @id @default(cuid())
  title     String?
  imageUrl  String
  linkType  String
  linkValue String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model ProductCategory {
  id        String      @id @default(cuid())
  name      String
  type      ProductType @default(TOPUP)
  order     Int         @default(0)
  gameId    String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  products  Product[]
  game      Game        @relation(fields: [gameId], references: [id])

  @@index([gameId])
}

model FlashSale {
  id         String   @id @default(cuid())
  productId  String
  flashPrice Int
  startAt    DateTime
  endAt      DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@index([productId, isActive])
  @@index([startAt, endAt])
}

model Voucher {
  id            String              @id @default(cuid())
  code          String              @unique
  target        Audience
  discountType  VoucherDiscountType
  discountValue Int
  minPurchase   Int                 @default(0)
  maxDiscount   Int?
  quotaTotal    Int?
  quotaUsed     Int                 @default(0)
  startAt       DateTime?
  endAt         DateTime?
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  orders        Order[]
  uses          VoucherUse[]

  @@index([isActive])
  @@index([target])
}

model VoucherUse {
  id        String   @id @default(cuid())
  voucherId String
  userId    String?
  orderId   String?  @unique
  usedAt    DateTime @default(now())
  order     Order?   @relation(fields: [orderId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
  voucher   Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@index([userId])
}

model PaymentMethodFee {
  id         String         @id @default(cuid())
  gateway    PaymentGateway
  methodKey  String
  feeFixed   Int            @default(0)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  feePercent Float
  label      String
  category   String         @default("Lainnya")
  image      String?
  maxFee     Int?
  minFee     Int?
  sortOrder  Int            @default(0)

  @@unique([gateway, methodKey])
  @@index([gateway, isActive])
}

model Deposit {
  id            String            @id @default(cuid())
  userId        String
  amount        Int
  channel       DepositChannel
  gateway       PaymentGateway?
  gatewayRef    String?
  status        DepositStatus     @default(PENDING)
  proofImageUrl String?
  adminNote     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  ledgerEntries CarenCoinLedger[]
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([gateway, gatewayRef])
}

model CarenCoinLedger {
  id           String         @id @default(cuid())
  userId       String
  type         CoinLedgerType
  amount       Int
  balanceAfter Int
  reason       String?
  refDepositId String?
  refOrderId   String?
  createdAt    DateTime       @default(now())
  deposit      Deposit?       @relation(fields: [refDepositId], references: [id])
  order        Order?         @relation(fields: [refOrderId], references: [id])
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([refOrderId])
  @@index([refDepositId])
}

model PointLedger {
  id           String          @id @default(cuid())
  userId       String
  type         PointLedgerType
  amount       Int
  balanceAfter Int
  reason       String?
  refOrderId   String?
  refUserId    String?
  createdAt    DateTime        @default(now())
  order        Order?          @relation(fields: [refOrderId], references: [id])
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([refOrderId])
}

model Order {
  id                String            @id @default(cuid())
  orderNo           String            @unique
  userId            String?
  serviceType       OrderServiceType  @default(TOPUP)
  status            OrderStatus       @default(PENDING_PAYMENT)
  gameId            String?
  productId         String?
  inputUserId       String?
  inputServer       String?
  contactWhatsapp   String
  contactEmail      String?
  voucherId         String?
  voucherDiscount   Int               @default(0)
  flashSaleId       String?
  flashPriceApplied Int?
  pointsUsed        Int               @default(0)
  pointsDiscount    Int               @default(0)
  basePrice         Int               @default(0)
  finalPayable      Int               @default(0)
  paymentMethod     PaymentMethod
  carencoinUsed     Int               @default(0)
  paymentGateway    PaymentGateway?
  gatewayMethodKey  String?
  gatewayFeeApplied Int               @default(0)
  paidAt            DateTime?
  expiresAt         DateTime?
  provider          Provider?
  providerTrxId     String?
  providerRaw       Json?
  costPrice         Int               @default(0)
  profit            Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  coinLedgers       CarenCoinLedger[]
  jokiDetail        JokiOrderDetail?
  flashSale         FlashSale?        @relation(fields: [flashSaleId], references: [id])
  game              Game?             @relation(fields: [gameId], references: [id])
  product           Product?          @relation(fields: [productId], references: [id])
  user              User?             @relation(fields: [userId], references: [id])
  voucher           Voucher?          @relation(fields: [voucherId], references: [id])
  payment           Payment?
  pointLedgers      PointLedger[]
  supportTickets    SupportTicket[]
  topupLogs         TopupLog[]
  voucherUse        VoucherUse?

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([serviceType])
  @@index([gameId])
  @@index([productId])
}

model Payment {
  id         String         @id @default(cuid())
  orderId    String         @unique
  gateway    PaymentGateway
  gatewayRef String
  status     PaymentStatus  @default(PENDING)
  rawPayload Json?
  paidAt     DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([gateway, gatewayRef])
  @@index([status])
}

model TopupLog {
  id              String   @id @default(cuid())
  orderId         String
  provider        Provider
  requestPayload  Json?
  responsePayload Json?
  statusSnapshot  String?
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model AdminAuditLog {
  id         String      @id @default(cuid())
  actorId    String
  action     AuditAction
  entityType String
  entityId   String?
  message    String?
  meta       Json?
  createdAt  DateTime    @default(now())
  actor      User        @relation("AdminActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([entityType])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model JokiOrderDetail {
  id             String            @id @default(cuid())
  orderId        String            @unique
  loginVia       JokiLoginVia
  userIdNickname String
  loginId        String
  password       String
  noteForJoki    String?
  status         JokiStatus        @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  heroRequests   JokiHeroRequest[]
  order          Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model JokiHeroRequest {
  id        String          @id @default(cuid())
  jokiId    String
  hero      String
  createdAt DateTime        @default(now())
  joki      JokiOrderDetail @relation(fields: [jokiId], references: [id], onDelete: Cascade)

  @@index([jokiId])
}

model GlobalSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String   @default("GENERAL")
  updatedAt DateTime @updatedAt
}

model SupportTicket {
  id        String         @id @default(cuid())
  ticketNo  String         @unique
  topic     String
  title     String
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(NORMAL)
  userId    String?
  contactWa String?
  orderId   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  order     Order?         @relation(fields: [orderId], references: [id])
  user      User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies   TicketReply[]

  @@index([userId])
  @@index([status])
  @@index([contactWa])
}

model TicketReply {
  id        String        @id @default(cuid())
  ticketId  String
  userId    String?
  message   String
  isAdmin   Boolean       @default(false)
  isSystem  Boolean       @default(false)
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User?         @relation(fields: [userId], references: [id])

  @@index([ticketId, createdAt])
}

model ProductReview {
  id         String   @id @default(cuid())
  userName   String
  rating     Int      @default(5)
  comment    String
  isVerified Boolean  @default(true)
  gameId     String?
  game       Game?    @relation(fields: [gameId], references: [id])
  createdAt  DateTime @default(now())

  @@index([gameId])
}

enum UserRole {
  MEMBER
  RESELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum Audience {
  PUBLIC
  MEMBER
  RESELLER
}

enum ProductGroup {
  BEST_SELLER
  HEMAT
  SULTAN
}

enum Provider {
  DIGIFLAZZ
  APIGAMES
}

enum ProductType {
  TOPUP
  JOKI
}

enum OrderServiceType {
  TOPUP
  JOKI_ML
  RESELLER_JOIN
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  CARENCOIN
  GATEWAY
}

enum PaymentGateway {
  XENDIT
  TRIPAY
  MIDTRANS
  DUITKU
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
}

enum DepositChannel {
  GATEWAY
  MANUAL
}

enum DepositStatus {
  PENDING
  PAID
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum CoinLedgerType {
  DEPOSIT
  PAYMENT
  ADJUST
  REFUND
}

enum PointLedgerType {
  EARN
  USE
  ADJUST
  REFUND
}

enum VoucherDiscountType {
  PERCENT
  FIXED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SUSPEND
  APPROVE
  REJECT
  ASSIGN
}

enum JokiLoginVia {
  MOONTON
  GOOGLE
  FACEBOOK
  VK
  TIKTOK
  TELEGRAM
}

enum JokiStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TicketStatus {
  OPEN
  ANSWERED
  CUSTOMER_REPLY
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
}
